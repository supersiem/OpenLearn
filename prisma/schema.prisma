model practice {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  list_id   String
  name      String
  mode      String
  subject   String
  lang_from String
  lang_to   String
  data      Json
  creator   String   @db.String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  published Boolean
}

model forum {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  post_id   String  @db.String @unique
  type      String
  replyTo   String?
  title     String
  subject   String
  content   String
  creator   String   @db.String
  locked    Boolean  @default(false)
  votes     Int      @db.Int @default(0)
  votes_data Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}